# Prefect Cloud API Configuration
# Copy this file to .env and fill in your actual values

PREFECT_API_KEY=your_prefect_api_key_here
ACCOUNT_ID=your_account_id_here
WORKSPACE_ID=your_workspace_id_here
# Not needed for the flow run - but needed for the API access
DEPLOYMENT_ID=your_deployment_id_here
GOOD_RUN=your_good_flow_run_id_here
FAILED_RUN=your_failed_flow_run_id_here